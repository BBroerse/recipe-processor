# Environment (development, production)
ENV=development

# Server
PORT=8080

# Database
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=recipes
DB_SSLMODE=disable
# DB_EXPOSE_PORT=5432  # host port for psql access (docker-compose only)

# Ollama
OLLAMA_MODEL=tinyllama

# Logging (debug, info, warn, error)
LOG_LEVEL=info
